// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              BigInt     @id @default(autoincrement()) @db.BigInt
  fullName        String     @map("full_name") @db.VarChar(150)
  email           String?    @unique @db.VarChar(255)
  phone           String?    @db.VarChar(30)
  passwordHash    String?    @map("password_hash") @db.Text
  role            String     @default("customer") @db.VarChar(30)
  status          String     @default("active") @db.VarChar(30)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  newsPosts       NewsPost[]
  carts           Cart[]
  orders          Order[]

  @@map("user")
}

model Category {
  id              BigInt     @id @default(autoincrement()) @db.BigInt
  parentId        BigInt?    @map("parent_id") @db.BigInt
  name            String     @db.VarChar(150)
  slug            String     @unique @db.VarChar(180)
  description     String?    @db.Text
  imageUrl        String?    @map("image_url") @db.Text
  metaTitle       String?    @map("meta_title") @db.VarChar(255)
  metaDescription String?    @map("meta_description") @db.Text
  sortOrder       Int        @default(0) @map("sort_order")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  parent          Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[] @relation("CategoryHierarchy")
  products        Product[]

  @@map("category")
}

model Product {
  id               BigInt         @id @default(autoincrement()) @db.BigInt
  categoryId       BigInt?        @map("category_id") @db.BigInt
  name             String         @db.VarChar(255)
  slug             String         @unique @db.VarChar(255)
  sku              String         @unique @db.VarChar(100)
  shortDescription String?        @map("short_description") @db.Text
  description      String?        @db.Text
  price            Decimal        @default(0) @db.Decimal(12, 0)
  salePrice        Decimal?       @map("sale_price") @db.Decimal(12, 0)
  costPrice        Decimal?       @map("cost_price") @db.Decimal(12, 0)
  stockQuantity    Int            @default(0) @map("stock_quantity")
  weightGrams      Int?           @map("weight_grams")
  thumbnail        String?        @db.Text
  metaTitle        String?        @map("meta_title") @db.VarChar(255)
  metaDescription  String?        @map("meta_description") @db.Text
  isFeatured       Boolean        @default(false) @map("is_featured")
  status           String         @default("draft") @db.VarChar(30)
  publishedAt      DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  cartItems        CartItem[]
  orderItems       OrderItem[]

  @@map("product")
}

model ProductImage {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  productId BigInt   @map("product_id") @db.BigInt
  imageUrl  String   @map("image_url") @db.Text
  altText   String?  @map("alt_text") @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_image")
}

model NewsPost {
  id              BigInt    @id @default(autoincrement()) @db.BigInt
  authorId        BigInt?   @map("author_id") @db.BigInt
  title           String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(255)
  excerpt         String?   @db.Text
  content         String    @db.Text
  thumbnail       String?   @db.Text
  metaTitle       String?   @map("meta_title") @db.VarChar(255)
  metaDescription String?   @map("meta_description") @db.Text
  status          String    @default("draft") @db.VarChar(30)
  publishedAt     DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  author          User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@map("news_post")
}

model Cart {
  id        BigInt     @id @default(autoincrement()) @db.BigInt
  userId    BigInt?    @map("user_id") @db.BigInt
  sessionId String?    @map("session_id") @db.VarChar(255)
  status    String     @default("active") @db.VarChar(30)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("cart")
}

model CartItem {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  cartId    BigInt   @map("cart_id") @db.BigInt
  productId BigInt   @map("product_id") @db.BigInt
  unitPrice Decimal  @default(0) @map("unit_price") @db.Decimal(12, 0)
  variant   String   @default("") @db.VarChar(100)
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId,variant])
  @@map("cart_items")
}

model Order {
  id                  BigInt      @id @default(autoincrement()) @db.BigInt
  orderCode           String      @unique @map("order_code") @db.VarChar(50)
  userId              BigInt?     @map("user_id") @db.BigInt
  customerName        String      @map("customer_name") @db.VarChar(150)
  customerPhone       String      @map("customer_phone") @db.VarChar(30)
  customerEmail       String?     @map("customer_email") @db.VarChar(255)
  shippingFullName    String?     @map("shipping_full_name") @db.VarChar(150)
  shippingPhone       String?     @map("shipping_phone") @db.VarChar(30)
  shippingAddressLine String      @map("shipping_address_line") @db.VarChar(255)
  shippingWard        String?     @map("shipping_ward") @db.VarChar(120)
  shippingDistrict    String?     @map("shipping_district") @db.VarChar(120)
  shippingProvince    String?     @map("shipping_province") @db.VarChar(120)
  shippingCountry     String      @default("Vietnam") @map("shipping_country") @db.VarChar(120)
  shippingPostalCode  String?     @map("shipping_postal_code") @db.VarChar(20)
  note                String?     @db.Text
  subtotal            Decimal     @default(0) @db.Decimal(12, 0)
  discountAmount      Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 0)
  shippingFee         Decimal     @default(0) @map("shipping_fee") @db.Decimal(12, 0)
  totalAmount         Decimal     @default(0) @map("total_amount") @db.Decimal(12, 0)
  paymentMethod       String      @default("cod") @map("payment_method") @db.VarChar(30)
  paymentStatus       String      @default("unpaid") @map("payment_status") @db.VarChar(30)
  orderStatus         String      @default("pending") @map("order_status") @db.VarChar(30)
  placedAt            DateTime    @default(now()) @map("placed_at") @db.Timestamptz(6)
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  payments            Payment[]

  @@map("order")
}

model OrderItem {
  id          BigInt   @id @default(autoincrement()) @db.BigInt
  orderId     BigInt   @map("order_id") @db.BigInt
  productId   BigInt?  @map("product_id") @db.BigInt
  productName String   @map("product_name") @db.VarChar(255)
  productSku  String?  @map("product_sku") @db.VarChar(100)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 0)
  variant     String   @default("") @db.VarChar(100)
  quantity    Int
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(12, 0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_item")
}

model Payment {
  id                    BigInt    @id @default(autoincrement()) @db.BigInt
  orderId               BigInt    @map("order_id") @db.BigInt
  paymentMethod         String    @map("payment_method") @db.VarChar(30)
  provider              String?   @db.VarChar(50)
  providerTransactionId String?   @map("provider_transaction_id") @db.VarChar(150)
  amount                Decimal   @default(0) @db.Decimal(12, 0)
  status                String    @default("pending") @db.VarChar(30)
  paidAt                DateTime? @map("paid_at") @db.Timestamptz(6)
  rawResponse           Json?     @map("raw_response") @db.JsonB
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payment")
}

model Banner {
  id             BigInt    @id @default(autoincrement()) @db.BigInt
  title          String?   @db.VarChar(255)
  imageUrl       String    @map("image_url") @db.Text
  mobileImageUrl String?   @map("mobile_image_url") @db.Text
  link           String?   @db.Text
  position       String?   @db.VarChar(100)
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  startAt        DateTime? @map("start_at") @db.Timestamptz(6)
  endAt          DateTime? @map("end_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("banner")
}
